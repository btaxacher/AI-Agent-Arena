FROM node:22-slim AS base

WORKDIR /app

# Copy root package files
COPY package.json package-lock.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/engine/package.json packages/engine/
COPY packages/api/package.json packages/api/

# Install all dependencies
RUN npm ci --ignore-scripts

# Copy source
COPY packages/shared/ packages/shared/
COPY packages/db/ packages/db/
COPY packages/engine/ packages/engine/
COPY packages/api/ packages/api/
COPY tsconfig.json ./

# Build packages in dependency order
RUN npm run build --workspace=packages/shared && \
    npm run build --workspace=packages/db && \
    npm run build --workspace=packages/engine && \
    npm run build --workspace=packages/api

# Production stage
FROM node:22-slim AS production

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/engine/package.json packages/engine/
COPY packages/api/package.json packages/api/

RUN npm ci --omit=dev --ignore-scripts

COPY --from=base /app/packages/shared/dist/ packages/shared/dist/
COPY --from=base /app/packages/db/dist/ packages/db/dist/
COPY --from=base /app/packages/engine/dist/ packages/engine/dist/
COPY --from=base /app/packages/api/dist/ packages/api/dist/

EXPOSE 3001

ENV PORT=3001
ENV NODE_ENV=production

CMD ["node", "packages/api/dist/index.js"]
